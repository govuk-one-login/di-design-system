  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@x-govuk/govuk-eleventy-plugin": "^8.3.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3"
  }
}
